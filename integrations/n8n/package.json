{
  "name": "n8n-nodes-klaket",
  "version": "0.1.0",
  "description": "n8n community node for Klaket — turn any video into LLM-ready data (transcripts, speakers, scenes, OCR, chapters, moment search)",
  "license": "MIT",
  "author": "Hüseyin Tıntaş",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huseyinstif/klaket.git",
    "directory": "integrations/n8n"
  },
  "homepage": "https://github.com/huseyinstif/klaket#readme",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "klaket",
    "video",
    "transcription",
    "whisper",
    "llm",
    "subtitles"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/KlaketApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Klaket/Klaket.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('nodes/Klaket/klaket.svg','dist/nodes/Klaket/klaket.svg')\"",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "n8n-workflow": "^1.70.0",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
